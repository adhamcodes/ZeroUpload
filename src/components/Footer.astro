---
import { CONVERSIONS, CATEGORIES } from "../data/conversions";

// Surface a curated set of high-volume conversions in the footer for crawl depth.
const slugs = ["heic-to-jpg", "png-to-jpg", "webp-to-png", "pdf-to-jpg", "jpg-to-pdf", "mp3-to-wav", "wav-to-mp3", "m4a-to-mp3"];
const popular = slugs
  .map((s) => CONVERSIONS.find((c) => c.slug === s))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-mist/70">
  <div class="mx-auto max-w-5xl px-6 py-12">
    <div class="flex flex-col gap-8 sm:flex-row sm:justify-between">
      <div class="max-w-xs">
        <p class="font-display text-lg">ZeroUpload</p>
        <p class="mt-2 text-sm text-stone">
          Convert files 100% in your browser. Zero uploads. Zero limits. Zero
          servers. Your files never leave your device.
        </p>
      </div>

      <div class="flex gap-12">
        <div>
          <p class="text-xs font-medium uppercase tracking-wider text-stone">
            Converters
          </p>
          <ul class="mt-3 space-y-2 text-sm">
            <li><a class="text-stone transition-colors hover:text-ink" href={`/${CATEGORIES.image.slug}`}>Image Converter</a></li>
            <li><a class="text-stone transition-colors hover:text-ink" href={`/${CATEGORIES.document.slug}`}>PDF Converter</a></li>
            <li><a class="text-stone transition-colors hover:text-ink" href={`/${CATEGORIES.audio.slug}`}>Audio Converter</a></li>
          </ul>
        </div>

        <div>
          <p class="text-xs font-medium uppercase tracking-wider text-stone">
            Popular
          </p>
          <ul class="mt-3 grid grid-cols-2 gap-x-8 gap-y-2 text-sm">
            {
              popular.map((c) => (
                <li>
                  <a
                    class="text-stone transition-colors hover:text-ink"
                    href={`/${c.slug}`}
                  >
                    {c.from.name} to {c.to.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <p class="text-xs font-medium uppercase tracking-wider text-stone">
            Company
          </p>
          <ul class="mt-3 space-y-2 text-sm">
            <li><a class="text-stone transition-colors hover:text-ink" href="/about">About</a></li>
            <li><a class="text-stone transition-colors hover:text-ink" href="/articles">Articles</a></li>
            <li><a class="text-stone transition-colors hover:text-ink" href="/privacy">Privacy Policy</a></li>
            <li><a class="text-stone transition-colors hover:text-ink" href="/terms">Terms of Service</a></li>
          </ul>
        </div>
      </div>
    </div>

    <p class="mt-10 text-xs text-stone">
      &copy; {year} ZeroUpload. Built for privacy. No file ever uploaded.
    </p>
  </div>
</footer>
