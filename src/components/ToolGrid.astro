---
interface Tool {
  name: string;
  description: string;
  href: string;
  comingSoon?: boolean;
}

interface Props {
  tools: Tool[];
}

const { tools } = Astro.props;

// Bespoke line-icon per tool, matched by keyword in the tool name.
// Each entry is an array of SVG <path>/<shape> markup strings.
function iconFor(name: string): string[] {
  const n = name.toLowerCase();
  if (n.includes("merge") || n.includes("combine") || n.includes("join"))
    return ['<rect x="3" y="4" width="8" height="16" rx="1"/>', '<rect x="13" y="8" width="8" height="12" rx="1"/>', '<path d="M11 12h2"/>'];
  if (n.includes("split"))
    return ['<rect x="4" y="3" width="16" height="18" rx="1"/>', '<path d="M12 3v18" stroke-dasharray="2 2"/>'];
  if (n.includes("compress") || n.includes("reduce"))
    return ['<path d="M8 4v4H4"/>', '<path d="M16 4v4h4"/>', '<path d="M8 20v-4H4"/>', '<path d="M16 20v-4h4"/>'];
  if (n.includes("resize"))
    return ['<path d="M15 3h6v6"/>', '<path d="M9 21H3v-6"/>', '<path d="M21 3l-7 7"/>', '<path d="M3 21l7-7"/>'];
  if (n.includes("crop"))
    return ['<path d="M6 2v14a2 2 0 0 0 2 2h14"/>', '<path d="M18 22V8a2 2 0 0 0-2-2H2"/>'];
  if (n.includes("rotate") || n.includes("flip"))
    return ['<path d="M21 2v6h-6"/>', '<path d="M3 12a9 9 0 0 1 15-6.7L21 8"/>', '<path d="M3 22v-6h6"/>', '<path d="M21 12a9 9 0 0 1-15 6.7L3 16"/>'];
  if (n.includes("reorder") || n.includes("organize") || n.includes("rearrange"))
    return ['<path d="M8 6h13"/>', '<path d="M8 12h13"/>', '<path d="M8 18h13"/>', '<path d="M3 6h.01"/>', '<path d="M3 12h.01"/>', '<path d="M3 18h.01"/>'];
  if (n.includes("trim") || n.includes("cut"))
    return ['<circle cx="6" cy="6" r="3"/>', '<circle cx="6" cy="18" r="3"/>', '<path d="M20 4L8.12 15.88"/>', '<path d="M14.47 14.48L20 20"/>', '<path d="M8.12 8.12L12 12"/>'];
  if (n.includes("to pdf") || n.includes("images to"))
    return ['<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>', '<path d="M14 2v6h6"/>'];
  if (n.includes("pdf to") || n.includes("to images") || n.includes("extract"))
    return ['<rect x="3" y="3" width="18" height="18" rx="2"/>', '<circle cx="9" cy="9" r="2"/>', '<path d="m21 15-3.5-3.5L11 18"/>'];
  if (n.includes("text") || n.includes("ocr"))
    return ['<path d="M4 7V4h16v3"/>', '<path d="M9 20h6"/>', '<path d="M12 4v16"/>'];
  // default: document
  return ['<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>', '<path d="M14 2v6h6"/>'];
}
---

<div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
  {
    tools.map((tool) => {
      const paths = iconFor(tool.name);
      const Wrapper = tool.comingSoon ? "div" : "a";
      return (
        <Wrapper
          href={tool.comingSoon ? undefined : tool.href}
          class={[
            "group relative rounded-[var(--radius-xl)] border border-mist bg-paper p-5 transition-all duration-200",
            tool.comingSoon
              ? "opacity-75"
              : "hover:-translate-y-0.5 hover:border-accent/60 hover:shadow-[var(--shadow-lifted)]",
          ].join(" ")}
        >
          {tool.comingSoon && (
            <span class="absolute top-3 right-3 rounded-full bg-mist px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-stone">
              Coming soon
            </span>
          )}

          <span class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg bg-accent-soft text-accent transition-colors">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={paths.join("")}
            />
          </span>

          <h3 class="font-display text-lg text-ink transition-colors group-hover:text-accent">
            {tool.name}
          </h3>
          <p class="mt-1 text-xs text-stone">{tool.description}</p>

          {!tool.comingSoon && (
            <span class="mt-3 block h-0.5 w-0 bg-brass transition-all duration-300 group-hover:w-8"></span>
          )}
        </Wrapper>
      );
    })
  }
</div>
