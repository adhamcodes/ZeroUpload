---
import Layout from "../layouts/Layout.astro";
import ImageResizer from "../components/ImageResizer.tsx";

const title =
  "Resize Image — Change Image Dimensions Free, In Your Browser | ZeroUpload";
const description =
  "Resize images by percentage or exact pixels — 100% in your browser. Free, unlimited, no upload, no signup. JPG, PNG, WEBP. Your images never leave your device.";

const steps = [
  { t: "Drop your images", d: "Add JPG, PNG, WEBP, GIF or BMP — they stay on your device." },
  { t: "Choose a size", d: "Resize by percentage, or set exact width/height with aspect lock." },
  { t: "Download", d: "Grab your resized images — one click each, no signup." },
];

const faqs = [
  { q: "Is this image resizer free?", a: "Completely — no signup, no watermark, no limit. There is no server doing the work, so there is nothing to charge for." },
  { q: "Are my images uploaded?", a: "No. Resizing runs entirely in your browser using the Canvas API. Your images never leave your device." },
  { q: "Can I keep the aspect ratio?", a: "Yes — lock the aspect ratio and set just a width (or height) and the other dimension is calculated for you." },
  { q: "Does resizing reduce file size?", a: "Usually yes — smaller dimensions mean fewer pixels and smaller files. You can also pick an output format for extra savings." },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "ZeroUpload Image Resizer",
    url: new URL("/resize-image", Astro.site).href,
    applicationCategory: "MultimediaApplication",
    operatingSystem: "Any (web browser)",
    description,
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-6 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-mist bg-surface-1 px-4 py-1.5 text-xs font-medium text-stone">
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>
    <h1 class="mt-6 font-display text-4xl leading-[1.08] tracking-tight sm:text-5xl">
      Resize images without<br /> uploading a thing.
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Change image dimensions by percentage or exact pixels — entirely in your
      browser. Free, unlimited, and your images never leave your device.
    </p>
  </section>

  <section class="mx-auto max-w-2xl px-6 py-6">
    <div class="rounded-[1.5rem] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-3)] sm:p-7">
      <ImageResizer client:load />
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="font-display text-3xl">How it works</h2>
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      {steps.map((s, i) => (
        <div>
          <div class="flex h-11 w-11 items-center justify-center rounded-full bg-accent-soft font-display text-accent">{i + 1}</div>
          <h3 class="mt-4 font-display text-xl">{s.t}</h3>
          <p class="mt-2 text-stone">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-3xl">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-mist/70">
      {faqs.map((f) => (
        <div class="py-5">
          <h3 class="font-display text-lg text-ink">{f.q}</h3>
          <p class="mt-2 text-stone">{f.a}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
