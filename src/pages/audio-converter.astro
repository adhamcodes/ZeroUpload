---
import Layout from "../layouts/Layout.astro";
import Converter from "../components/Converter.tsx";
import ToolGrid from "../components/ToolGrid.astro";
import ConversionGrid from "../components/ConversionGrid.astro";
import {
  conversionsByCategory,
  CATEGORIES,
  CONVERSIONS,
  FORMAT_BY_ID,
} from "../data/conversions";

const cat = CATEGORIES.audio;
const list = conversionsByCategory("audio");

// File-first converter wiring (data-driven; engines untouched).
const formatIds = ["mp3", "wav", "ogg", "m4a", "flac", "aac"];
const pairs = CONVERSIONS.filter(
  (c) =>
    c.engine === "audio" &&
    formatIds.includes(c.from.id) &&
    formatIds.includes(c.to.id),
);
const engineMap = Object.fromEntries(
  pairs.map((c) => [`${c.from.id}-${c.to.id}`, c.engine]),
);
const sources = formatIds.map((id) => ({
  id,
  name: FORMAT_BY_ID[id].name,
  accept: FORMAT_BY_ID[id].accept ?? `.${id},${FORMAT_BY_ID[id].mime}`,
}));
const targets = formatIds.map((id) => ({ id, name: FORMAT_BY_ID[id].name }));

const tools = [
  { name: "Trim/Cut Audio", description: "Cut a section from an audio file", href: "#", comingSoon: true },
  { name: "Merge Audio", description: "Combine multiple audio files", href: "#", comingSoon: true },
  { name: "Compress Audio", description: "Reduce audio file size", href: "#", comingSoon: true },
];

const title = "Free Audio Converter — MP3, WAV, FLAC, M4A In Your Browser | ZeroUpload";
const description =
  "Convert MP3, WAV, OGG, M4A, FLAC and AAC audio instantly in your browser with ffmpeg. 100% private — no upload, no signup, no limits. Your audio never leaves your device.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: cat.title,
    description,
    url: new URL("/audio-converter", Astro.site).href,
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-8 text-center">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-mist bg-paper px-4 py-1.5 text-xs font-medium text-stone"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>

    <h1 class="mt-6 font-display text-4xl tracking-tight sm:text-5xl">
      {cat.title}
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Your files are nobody's business. Convert audio files locally with ffmpeg
      running in your browser. Your media never leaves your machine.
    </p>
  </section>

  <!-- File-first converter -->
  <section class="mx-auto max-w-2xl px-6 py-8">
    <Converter
      client:load
      sources={sources}
      targets={targets}
      engineMap={engineMap}
      defaultTo="mp3"
    />
  </section>

  <!-- Tool Grid -->
  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="font-display text-2xl">Audio tools</h2>
    <p class="mt-1 text-stone">Everything runs on your device.</p>
    <div class="mt-8">
      <ToolGrid tools={tools} />
    </div>
  </section>

  <!-- All Conversions -->
  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="font-display text-2xl">All audio conversions</h2>
    <div class="mt-8">
      <ConversionGrid conversions={list} />
    </div>
    <p class="mt-6 text-xs text-stone/80">
      Note: the audio engine downloads once (about 32 MB) from this site on first
      use, then is cached by your browser. Audio still never leaves your device.
    </p>
  </section>
</Layout>
