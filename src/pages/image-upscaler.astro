---
import Layout from "../layouts/Layout.astro";
import ImageUpscaler from "../components/ImageUpscaler.tsx";
import { UPSCALE_VARIANTS } from "../data/upscaleVariants";

const title =
  "Free Image Upscaler (Beta) — Enlarge Images up to 4× In Your Browser | ZeroUpload";
const description =
  "Enlarge and sharpen images up to 4× — 100% in your browser. Free, unlimited, no signup, no upload, no watermark. Your image never leaves your device.";

const steps = [
  {
    t: "Drop your image",
    d: "Drag in a small or soft JPG, PNG or WEBP — or click to choose. It stays on your device.",
  },
  {
    t: "It enlarges up to 4×",
    d: "An on-device model enlarges the image up to four times over and sharpens its edges.",
  },
  {
    t: "Drag to compare & download",
    d: "Reveal the before/after with the slider, then save the larger PNG.",
  },
];

const faqs = [
  {
    q: "Is this image upscaler really free?",
    a: "Yes — completely free with no signup, no watermark and no per-image limit. There is no server doing the work, so there is nothing to meter or charge for.",
  },
  {
    q: "Are my images uploaded anywhere?",
    a: "No. The work happens entirely inside your browser using an on-device model. Your image never leaves your device. The only thing downloaded is the model itself, the first time you use the tool.",
  },
  {
    q: "Will it 'restore' an old photo or fix a blurry face?",
    a: "Honestly, no — and we won't pretend otherwise. The viral 'restore a face' tools run heavy AI on GPU servers, which means uploading your photo. We refuse to do that. This tool enlarges and sharpens what is already in the image; it cannot invent eyes, noses or detail that were never captured. That's why it's labelled Beta.",
  },
  {
    q: "What does it actually do well?",
    a: "Enlarging small, fairly clean images so they stay sharp instead of blocky — logos, icons, product shots, screenshots, web-sized pictures, and clean photos. For anime, illustrations and line art, switch on Anime & Art mode, where it genuinely shines.",
  },
  {
    q: "What's the difference between Photo and Anime mode?",
    a: "Photo mode uses a model trained on real photographs — it sharpens faithfully without restyling faces. Anime & Art mode uses a model trained on drawings, which keeps line art crisp and vivid, but it will make a real photo look cartoonish. Photo is the default; use Anime only for art and graphics.",
  },
  {
    q: "How much does it enlarge the image?",
    a: "Up to 4× — width and height each grow up to four times (about 16× the pixels). Large images are scaled to fit first so the tool stays fast and won't crash your tab.",
  },
  {
    q: "Why is it slow, and does it work on phones?",
    a: "It's real AI doing real work on your device. Where your browser supports WebGPU it uses your graphics card and is much faster; otherwise it falls back to a slower CPU path. A recent desktop browser is best. On phones and low-memory devices the input is capped automatically to avoid freezing or running out of memory.",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "ZeroUpload Image Upscaler (Beta)",
    url: new URL("/image-upscaler", Astro.site).href,
    applicationCategory: "MultimediaApplication",
    operatingSystem: "Any (web browser)",
    description,
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-6 text-center">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-mist bg-paper px-4 py-1.5 text-xs font-medium text-stone"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      Runs on your device · nothing is ever uploaded · Beta
    </span>

    <h1 class="mt-6 font-display text-4xl leading-[1.08] tracking-tight sm:text-5xl">
      Enlarge images up to 4×<br /> without uploading a thing.
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Drop a small image and it's enlarged up to 4× with sharper edges — free,
      unlimited, no signup. It runs entirely inside your browser, so your image
      never leaves your device. Best for graphics, screenshots and clean photos;
      it sharpens what's there, it doesn't magically restore detail.
    </p>
  </section>

  <!-- The tool -->
  <section class="mx-auto max-w-2xl px-6 py-6">
    <ImageUpscaler client:only="react" />
  </section>

  <!-- How it works -->
  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="font-display text-3xl">How it works</h2>
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      {
        steps.map((s, i) => (
          <div>
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-accent-soft font-display text-accent">
              {i + 1}
            </div>
            <h3 class="mt-4 font-display text-xl">{s.t}</h3>
            <p class="mt-2 text-stone">{s.d}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Privacy statement -->
  <section class="mx-auto max-w-3xl px-6 py-12 text-center">
    <h2 class="font-display text-3xl">Your photos are nobody's business.</h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Other upscalers upload your private photos to their servers and charge you
      per image or lock results behind a subscription. ZeroUpload does the
      opposite: the AI model comes to your browser, your photo stays put, and
      there is no limit because there is no server.
    </p>
  </section>

  <!-- Use cases / programmatic SEO links -->
  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="font-display text-2xl">One tool, every kind of image</h2>
    <p class="mt-1 text-stone">Tuned copy and tips for the most common needs.</p>
    <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        UPSCALE_VARIANTS.map((v) => (
          <a
            href={`/${v.slug}`}
            class="group rounded-[var(--radius-lg)] border border-mist bg-paper px-5 py-4 transition-all hover:border-accent/60 hover:shadow-[var(--shadow-1)]"
          >
            <span class="text-ink transition-colors group-hover:text-accent">
              {v.label}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-3xl">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-mist/70">
      {
        faqs.map((f) => (
          <div class="py-5">
            <h3 class="font-display text-lg text-ink">{f.q}</h3>
            <p class="mt-2 text-stone">{f.a}</p>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
