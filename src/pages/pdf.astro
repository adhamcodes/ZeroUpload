---
import Layout from "../layouts/Layout.astro";
import Converter from "../components/Converter.tsx";
import ToolGrid from "../components/ToolGrid.astro";
import ConversionGrid from "../components/ConversionGrid.astro";
import {
  conversionsByCategory,
  CONVERSIONS,
  FORMAT_BY_ID,
} from "../data/conversions";

const list = conversionsByCategory("document");

// File-first converter wiring (data-driven; engines untouched).
const sourceIds = ["pdf", "jpg", "jpeg", "png", "webp"];
const targetIds = ["pdf", "jpg", "png"];
const allowedEngines = new Set(["pdf2img", "img2pdf"]);
const pairs = CONVERSIONS.filter(
  (c) =>
    allowedEngines.has(c.engine) &&
    sourceIds.includes(c.from.id) &&
    targetIds.includes(c.to.id),
);
const engineMap = Object.fromEntries(
  pairs.map((c) => [`${c.from.id}-${c.to.id}`, c.engine]),
);
const sources = sourceIds.map((id) => ({
  id,
  name: FORMAT_BY_ID[id].name,
  accept: FORMAT_BY_ID[id].accept ?? `.${id},${FORMAT_BY_ID[id].mime}`,
}));
const targets = targetIds.map((id) => ({ id, name: FORMAT_BY_ID[id].name }));

const tools = [
  { name: "Merge PDF", description: "Combine multiple PDFs into one", href: "/merge-pdf" },
  { name: "Split PDF", description: "Split a PDF or extract pages", href: "/split-pdf" },
  { name: "Compress PDF", description: "Reduce PDF file size", href: "#", comingSoon: true },
  { name: "Rotate PDF", description: "Rotate PDF pages", href: "#", comingSoon: true },
  { name: "Reorder Pages", description: "Rearrange pages in a PDF", href: "#", comingSoon: true },
  { name: "Images to PDF", description: "Combine images into a PDF", href: "/jpg-to-pdf", comingSoon: false },
  { name: "PDF to Images", description: "Extract PDF pages as images", href: "/pdf-to-jpg", comingSoon: false },
  { name: "PDF to Text", description: "Extract text from a PDF", href: "/pdf-to-text" },
];

const title = "Free PDF Tools — Convert, Merge, Split PDFs In Your Browser | ZeroUpload";
const description =
  "Convert PDF to images, images to PDF, and more. 100% private — no upload, no signup, no limits. Your documents never leave your device.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "PDF Tools",
    description,
    url: new URL("/pdf", Astro.site).href,
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-8 text-center">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-mist bg-paper px-4 py-1.5 text-xs font-medium text-stone"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>

    <h1 class="mt-6 font-display text-4xl tracking-tight sm:text-5xl">
      PDF Tools
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Your files are nobody's business. Convert, combine and extract PDFs
      entirely in your browser — no upload, no server, no limits.
    </p>
  </section>

  <!-- File-first converter -->
  <section class="mx-auto max-w-2xl px-6 py-8">
    <Converter
      client:load
      sources={sources}
      targets={targets}
      engineMap={engineMap}
      defaultTo="pdf"
    />
  </section>

  <!-- Tool Grid -->
  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="font-display text-2xl">PDF tools</h2>
    <p class="mt-1 text-stone">Everything runs on your device.</p>
    <div class="mt-8">
      <ToolGrid tools={tools} />
    </div>
  </section>

  <!-- All Conversions -->
  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="font-display text-2xl">All PDF conversions</h2>
    <div class="mt-8">
      <ConversionGrid conversions={list} />
    </div>
  </section>
</Layout>
