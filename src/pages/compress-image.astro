---
import Layout from "../layouts/Layout.astro";
import ImageCompressor from "../components/ImageCompressor.tsx";
import { COMPRESS_SUBJECTS } from "../data/compressFormats";

const title =
  "Compress Image — Reduce Image File Size Free, In Your Browser | ZeroUpload";
const description =
  "Compress JPG, PNG and WEBP images and shrink their file size — 100% in your browser. Free, unlimited, no upload, no signup. Your images never leave your device.";

const steps = [
  { t: "Drop your images", d: "Add JPG, PNG, WEBP, GIF or BMP — they stay on your device." },
  { t: "Set the quality", d: "Drag the slider, pick a format, optionally resize. See the savings live." },
  { t: "Download", d: "Grab your smaller images — one click each, no signup." },
];

const faqs = [
  { q: "Is this image compressor free?", a: "Completely — no signup, no watermark, no limit on how many images you compress. There is no server doing the work, so there is nothing to charge for." },
  { q: "Are my images uploaded?", a: "No. Compression runs entirely in your browser using the Canvas API. Your images never leave your device." },
  { q: "How much smaller will my images get?", a: "It depends on the image and your quality setting — photos often shrink 60–90% at 70–85% quality with no visible difference. The tool shows the exact savings for each file." },
  { q: "Will it reduce quality?", a: "You control it. JPG and WEBP are lossy, so lower quality = smaller file. PNG is lossless. You can preview the size trade-off instantly with the slider." },
  { q: "Can I resize at the same time?", a: "Yes — pick a maximum dimension (e.g. 1920px) and images are downscaled before compressing, for even smaller files." },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "ZeroUpload Image Compressor",
    url: new URL("/compress-image", Astro.site).href,
    applicationCategory: "MultimediaApplication",
    operatingSystem: "Any (web browser)",
    description,
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-6 text-center">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-mist bg-surface-1 px-4 py-1.5 text-xs font-medium text-stone"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>
    <h1 class="mt-6 font-display text-4xl leading-[1.08] tracking-tight sm:text-5xl">
      Compress images without<br /> uploading a thing.
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Shrink JPG, PNG and WEBP file sizes with a live quality slider — entirely
      in your browser. Free, unlimited, and your images never leave your device.
    </p>
  </section>

  <!-- Tool -->
  <section class="mx-auto max-w-2xl px-6 py-6">
    <div class="rounded-[1.5rem] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-3)] sm:p-7">
      <ImageCompressor client:load />
    </div>
  </section>

  <!-- How it works -->
  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="font-display text-3xl">How it works</h2>
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      {
        steps.map((s, i) => (
          <div>
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-accent-soft font-display text-accent">
              {i + 1}
            </div>
            <h3 class="mt-4 font-display text-xl">{s.t}</h3>
            <p class="mt-2 text-stone">{s.d}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Per-format links -->
  <section class="mx-auto max-w-5xl px-6 py-10">
    <h2 class="font-display text-2xl">Compress by format</h2>
    <div class="mt-7 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {
        COMPRESS_SUBJECTS.map((s) => (
          <a
            href={`/compress-${s.slug}`}
            class="group rounded-[var(--radius-lg)] border border-mist bg-surface-1 px-5 py-4 transition-all hover:border-accent/60 hover:shadow-[var(--shadow-2)]"
          >
            <span class="text-ink transition-colors group-hover:text-accent">
              Compress {s.name}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-3xl">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-mist/70">
      {
        faqs.map((f) => (
          <div class="py-5">
            <h3 class="font-display text-lg text-ink">{f.q}</h3>
            <p class="mt-2 text-stone">{f.a}</p>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
