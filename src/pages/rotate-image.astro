---
import Layout from "../layouts/Layout.astro";
import RotateImage from "../components/RotateImage.tsx";

const title = "Rotate & Flip Image — Free, In Your Browser | ZeroUpload";
const description =
  "Rotate or flip images by 90° — 100% in your browser. Free, unlimited, no upload, no signup. JPG, PNG, WEBP. Your images never leave your device.";

const faqs = [
  { q: "Is this rotate tool free?", a: "Completely — no signup, no watermark, no limit. There is no server, so there is nothing to charge for." },
  { q: "Are my images uploaded?", a: "No. Rotating and flipping run entirely in your browser using the Canvas API. Your images never leave your device." },
  { q: "Can I rotate many images at once?", a: "Yes — drop a batch and the same rotation and flip are applied to all of them." },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "ZeroUpload Rotate & Flip Image",
    url: new URL("/rotate-image", Astro.site).href,
    applicationCategory: "MultimediaApplication",
    operatingSystem: "Any (web browser)",
    description,
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-6 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-mist bg-surface-1 px-4 py-1.5 text-xs font-medium text-stone">
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>
    <h1 class="mt-6 font-display text-4xl leading-[1.08] tracking-tight sm:text-5xl">
      Rotate & flip images<br /> without uploading a thing.
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Turn images 90°, 180°, or mirror them — entirely in your browser. Free,
      unlimited, and your images never leave your device.
    </p>
  </section>

  <section class="mx-auto max-w-2xl px-6 py-6">
    <div class="rounded-[1.5rem] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-3)] sm:p-7">
      <RotateImage client:load />
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-3xl">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-mist/70">
      {faqs.map((f) => (
        <div class="py-5">
          <h3 class="font-display text-lg text-ink">{f.q}</h3>
          <p class="mt-2 text-stone">{f.a}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
