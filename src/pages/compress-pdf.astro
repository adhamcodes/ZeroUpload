---
import Layout from "../layouts/Layout.astro";
import PdfCompress from "../components/PdfCompress.tsx";

const title = "Compress PDF — Free Online PDF Compressor, In Your Browser | ZeroUpload";
const description =
  "Reduce PDF file size — 100% in your browser. Free, unlimited, no upload, no signup. Best for scans and image-heavy PDFs. Your PDF never leaves your device.";

const faqs = [
  { q: "Is compressing a PDF free?", a: "Completely — no signup, no watermark, no limit. There is no server, so there is nothing to charge for." },
  { q: "Is my PDF uploaded?", a: "No. Compression runs entirely in your browser. Your PDF never leaves your device." },
  { q: "Will the text still be selectable?", a: "No — this light compressor flattens each page to an image to shrink the file, so the text becomes part of the picture and is no longer selectable or searchable. It is best for scans and image-heavy PDFs. We tell you this up front because we would rather be honest than surprise you." },
  { q: "Why didn't my PDF get much smaller?", a: "Text-only PDFs are already tiny and compress poorly when flattened to images, so you may see little or no gain. Image-heavy PDFs and scans shrink the most." },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebApplication", name: "ZeroUpload PDF Compressor", url: new URL("/compress-pdf", Astro.site).href, applicationCategory: "UtilitiesApplication", operatingSystem: "Any (web browser)", description, offers: { "@type": "Offer", price: "0", priceCurrency: "USD" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-6 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-mist bg-surface-1 px-4 py-1.5 text-xs font-medium text-stone">
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>
    <h1 class="mt-6 font-display text-4xl leading-[1.08] tracking-tight sm:text-5xl">Compress a PDF without<br /> uploading a thing.</h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">Shrink scans and image-heavy PDFs entirely in your browser — free, unlimited, private. We will be honest about what it can and can't do.</p>
  </section>

  <section class="mx-auto max-w-2xl px-6 py-6">
    <div class="rounded-[1.5rem] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-3)] sm:p-7">
      <PdfCompress client:load />
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-3xl">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-mist/70">
      {faqs.map((f) => (<div class="py-5"><h3 class="font-display text-lg text-ink">{f.q}</h3><p class="mt-2 text-stone">{f.a}</p></div>))}
    </div>
  </section>
</Layout>
