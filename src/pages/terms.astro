---
import Layout from "../layouts/Layout.astro";

const title = "Terms of Service | ZeroUpload";
const description =
  "The terms of service for using ZeroUpload, the free in-browser file converter.";
const updated = "June 2026";
---

<Layout title={title} description={description}>
  <article class="mx-auto max-w-2xl px-6 pt-16 pb-20">
    <h1 class="font-display text-4xl tracking-tight sm:text-5xl">Terms of Service</h1>
    <p class="mt-3 text-sm text-stone">Last updated: {updated}</p>

    <div class="article-body mt-8 space-y-4 text-stone leading-relaxed">
      <h2 class="font-display text-2xl text-ink">Acceptance of terms</h2>
      <p>
        By using ZeroUpload, you agree to these terms. If you do not agree, please
        do not use the service.
      </p>

      <h2 class="font-display text-2xl text-ink">The service</h2>
      <p>
        ZeroUpload provides free, browser-based file conversion tools. Conversions
        run entirely on your device. The service is provided free of charge for
        personal and commercial use.
      </p>

      <h2 class="font-display text-2xl text-ink">Acceptable use</h2>
      <p>
        You agree to use ZeroUpload only with files you have the legal right to
        convert, and not for any unlawful purpose. You are solely responsible for
        the files you process and the results you produce.
      </p>

      <h2 class="font-display text-2xl text-ink">No warranty</h2>
      <p>
        The service is provided "as is," without warranties of any kind. While we
        work hard to ensure accurate, reliable conversions, we cannot guarantee
        that every conversion will be error-free or suitable for every purpose.
        Always keep a copy of your original files.
      </p>

      <h2 class="font-display text-2xl text-ink">Limitation of liability</h2>
      <p>
        To the maximum extent permitted by law, ZeroUpload is not liable for any
        loss or damage arising from your use of the service, including any loss of
        data. Because your files are never uploaded to us, we never hold or
        control them.
      </p>

      <h2 class="font-display text-2xl text-ink">Changes to these terms</h2>
      <p>
        We may revise these terms from time to time. Continued use of the service
        after changes constitutes acceptance of the revised terms.
      </p>

      <h2 class="font-display text-2xl text-ink">Contact</h2>
      <p>Questions? Email <strong>hello@zeroupload.app</strong>.</p>
    </div>
  </article>
</Layout>

<style>
  .article-body :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
</style>
