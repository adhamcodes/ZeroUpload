---
import Layout from "../layouts/Layout.astro";
import RotatePdf from "../components/RotatePdf.tsx";

const title = "Rotate PDF — Free Online PDF Rotator, In Your Browser | ZeroUpload";
const description =
  "Rotate PDF pages 90° or 180° — 100% in your browser. Free, unlimited, no upload, no signup. Lossless. Your PDF never leaves your device.";

const faqs = [
  { q: "Is rotating a PDF free?", a: "Completely — no signup, no watermark, no limit. There is no server, so there is nothing to charge for." },
  { q: "Is my PDF uploaded?", a: "No. Rotation runs entirely in your browser. Your PDF never leaves your device." },
  { q: "Does it lose quality?", a: "No — rotating a PDF is lossless. The pages are simply turned; nothing is re-compressed." },
  { q: "Does it rotate every page?", a: "Yes — the chosen rotation is applied to all pages, which fixes sideways scans in one click." },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebApplication", name: "ZeroUpload PDF Rotator", url: new URL("/rotate-pdf", Astro.site).href, applicationCategory: "UtilitiesApplication", operatingSystem: "Any (web browser)", description, offers: { "@type": "Offer", price: "0", priceCurrency: "USD" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-6 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-mist bg-surface-1 px-4 py-1.5 text-xs font-medium text-stone">
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>
    <h1 class="mt-6 font-display text-4xl leading-[1.08] tracking-tight sm:text-5xl">Rotate a PDF without<br /> uploading a thing.</h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">Turn sideways or upside-down pages the right way up — entirely in your browser. Free, unlimited, lossless.</p>
  </section>

  <section class="mx-auto max-w-2xl px-6 py-6">
    <div class="rounded-[1.5rem] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-3)] sm:p-7">
      <RotatePdf client:load />
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-3xl">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-mist/70">
      {faqs.map((f) => (<div class="py-5"><h3 class="font-display text-lg text-ink">{f.q}</h3><p class="mt-2 text-stone">{f.a}</p></div>))}
    </div>
  </section>
</Layout>
