---
import Layout from "../layouts/Layout.astro";
import Converter from "../components/Converter.tsx";
import ToolGrid from "../components/ToolGrid.astro";
import ConversionGrid from "../components/ConversionGrid.astro";
import {
  conversionsByCategory,
  CATEGORIES,
  CONVERSIONS,
  FORMAT_BY_ID,
} from "../data/conversions";

const cat = CATEGORIES.image;
const list = conversionsByCategory("image").filter((c) => c.engine !== "img2pdf");

// File-first converter wiring (data-driven; engines untouched).
const sourceIds = ["png", "jpg", "jpeg", "webp", "gif", "bmp", "svg", "heic"];
const targetIds = ["png", "jpg", "jpeg", "webp"];
const allowedEngines = new Set(["image", "heic"]);
const pairs = CONVERSIONS.filter(
  (c) =>
    allowedEngines.has(c.engine) &&
    sourceIds.includes(c.from.id) &&
    targetIds.includes(c.to.id),
);
const engineMap = Object.fromEntries(
  pairs.map((c) => [`${c.from.id}-${c.to.id}`, c.engine]),
);
const sources = sourceIds.map((id) => ({
  id,
  name: FORMAT_BY_ID[id].name,
  accept: FORMAT_BY_ID[id].accept ?? `.${id},${FORMAT_BY_ID[id].mime}`,
}));
const targets = targetIds.map((id) => ({ id, name: FORMAT_BY_ID[id].name }));

const tools = [
  { name: "Compress Image", description: "Reduce image file size", href: "/compress-image" },
  { name: "Resize Image", description: "Change image dimensions", href: "/resize-image" },
  { name: "Crop Image", description: "Crop to a specific area", href: "/crop-image" },
  { name: "Rotate/Flip Image", description: "Rotate or mirror an image", href: "/rotate-image" },
];

const title = "Free Image Converter — Convert Images In Your Browser | ZeroUpload";
const description =
  "Convert PNG, JPG, WEBP, HEIC, SVG, GIF and BMP images instantly in your browser. 100% private — no upload, no signup, no limits. Files never leave your device.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: cat.title,
    description,
    url: new URL("/image-converter", Astro.site).href,
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-8 text-center">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-mist bg-paper px-4 py-1.5 text-xs font-medium text-stone"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>

    <h1 class="mt-6 font-display text-4xl tracking-tight sm:text-5xl">
      {cat.title}
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Your files are nobody's business. Convert images instantly, entirely in
      your browser. No upload, no server, no limits.
    </p>
  </section>

  <!-- File-first converter -->
  <section class="mx-auto max-w-2xl px-6 py-8">
    <Converter
      client:load
      sources={sources}
      targets={targets}
      engineMap={engineMap}
      defaultTo="png"
    />
  </section>

  <!-- Tool Grid -->
  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="font-display text-2xl">Image tools</h2>
    <p class="mt-1 text-stone">Everything runs on your device.</p>
    <div class="mt-8">
      <ToolGrid tools={tools} />
    </div>
  </section>

  <!-- All Conversions -->
  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="font-display text-2xl">All image conversions</h2>
    <div class="mt-8">
      <ConversionGrid conversions={list} />
    </div>
  </section>
</Layout>
