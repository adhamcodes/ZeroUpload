---
import Layout from "../layouts/Layout.astro";
import FormatPicker from "../components/FormatPicker.tsx";
import ToolGrid from "../components/ToolGrid.astro";
import ConversionGrid from "../components/ConversionGrid.astro";
import { conversionsByCategory, CATEGORIES } from "../data/conversions";

const cat = CATEGORIES.image;
const list = conversionsByCategory("image").filter((c) => c.engine !== "img2pdf");

const sources = [
  { id: "png", name: "PNG" },
  { id: "jpg", name: "JPG" },
  { id: "jpeg", name: "JPEG" },
  { id: "webp", name: "WEBP" },
  { id: "gif", name: "GIF" },
  { id: "bmp", name: "BMP" },
  { id: "svg", name: "SVG" },
  { id: "heic", name: "HEIC" },
];

const targets = [
  { id: "png", name: "PNG" },
  { id: "jpg", name: "JPG" },
  { id: "jpeg", name: "JPEG" },
  { id: "webp", name: "WEBP" },
];

const tools = [
  { name: "Compress Image", description: "Reduce image file size", href: "#", comingSoon: true },
  { name: "Resize Image", description: "Change image dimensions", href: "#", comingSoon: true },
  { name: "Crop Image", description: "Crop to a specific area", href: "#", comingSoon: true },
  { name: "Rotate/Flip Image", description: "Rotate or mirror an image", href: "#", comingSoon: true },
];

const title = "Free Image Converter — Convert Images In Your Browser | ZeroUpload";
const description =
  "Convert PNG, JPG, WEBP, HEIC, SVG, GIF and BMP images instantly in your browser. 100% private — no upload, no signup, no limits. Files never leave your device.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: cat.title,
    description,
    url: new URL("/image-converter", Astro.site).href,
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="mx-auto max-w-3xl px-6 pt-12 pb-4 text-center">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-mist bg-paper px-4 py-1.5 text-xs font-medium text-stone"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>

    <h1 class="mt-6 font-display text-4xl leading-tight tracking-tight sm:text-5xl">
      {cat.title}
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Your files are nobody's business. Convert images instantly, entirely in
      your browser. No upload, no server, no limits.
    </p>
  </section>

  <!-- Format Picker -->
  <section class="mx-auto max-w-2xl px-6 py-6">
    <div class="surface-raised rounded-[var(--radius-xl)] p-6">
      <FormatPicker
        client:load
        sources={sources}
        targets={targets}
        defaultFrom="png"
        defaultTo="jpg"
      />
    </div>
  </section>

  <!-- Tool Grid -->
  <section class="mx-auto max-w-5xl px-6 py-6">
    <h2 class="font-display text-2xl">Image tools</h2>
    <p class="mt-1 text-stone">Everything runs on your device.</p>
    <div class="mt-8">
      <ToolGrid tools={tools} />
    </div>
  </section>

  <!-- All Conversions -->
  <section class="mx-auto max-w-5xl px-6 py-6">
    <h2 class="font-display text-2xl">All image conversions</h2>
    <div class="mt-8">
      <ConversionGrid conversions={list} />
    </div>
  </section>
</Layout>
