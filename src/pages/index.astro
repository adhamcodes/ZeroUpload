---
import Layout from "../layouts/Layout.astro";
import Converter from "../components/Converter.tsx";
import ConversionGrid from "../components/ConversionGrid.astro";
import { CONVERSIONS, FORMAT_BY_ID } from "../data/conversions";

const title =
  "ZeroUpload — Convert Files 100% in Your Browser. Zero Uploads, Zero Limits.";
const description =
  "Convert images, PDFs and audio privately and instantly. Files never leave your device — no upload, no signup, no limits. Works even offline. The private file converter.";

// ---- Universal converter wiring: every conversion in one floating console ----
const sourceIds = Array.from(new Set(CONVERSIONS.map((c) => c.from.id)));
const targetIds = Array.from(new Set(CONVERSIONS.map((c) => c.to.id)));
const engineMap = Object.fromEntries(
  CONVERSIONS.map((c) => [`${c.from.id}-${c.to.id}`, c.engine]),
);
const sources = sourceIds.map((id) => ({
  id,
  name: FORMAT_BY_ID[id].name,
  accept: FORMAT_BY_ID[id].accept ?? `.${id},${FORMAT_BY_ID[id].mime}`,
}));
const targets = targetIds.map((id) => ({ id, name: FORMAT_BY_ID[id].name }));

// ---- Popular conversions (dense grid) ----
const featuredSlugs = [
  "heic-to-jpg", "png-to-jpg", "jpg-to-png", "webp-to-png",
  "png-to-webp", "jpg-to-webp", "svg-to-png", "gif-to-png",
  "pdf-to-jpg", "pdf-to-png", "jpg-to-pdf", "png-to-pdf",
  "mp3-to-wav", "wav-to-mp3", "m4a-to-mp3", "flac-to-mp3",
];
const featured = featuredSlugs
  .map((s) => CONVERSIONS.find((c) => c.slug === s))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

// ---- Tool suites ----
const toolCards = [
  { title: "Image Tools", href: "/image-converter", blurb: "PNG · JPG · WEBP · HEIC · SVG · GIF · BMP", icon: "image" },
  { title: "PDF Tools", href: "/pdf", blurb: "PDF ↔ images, and more coming", icon: "pdf" },
  { title: "Audio Tools", href: "/audio-converter", blurb: "MP3 · WAV · OGG · M4A · FLAC · AAC", icon: "audio" },
  { title: "AI Image Upscaler", href: "/image-upscaler", blurb: "Unblur & enlarge images 4× on-device", icon: "upscale", badge: "AI" },
  { title: "AI Background Remover", href: "/background-remover", blurb: "Erase backgrounds on-device", icon: "bg", badge: "AI" },
];

// ---- Supported formats showcase ----
const formatGroups = [
  { label: "Images", items: ["PNG", "JPG", "JPEG", "WEBP", "GIF", "BMP", "SVG", "HEIC"] },
  { label: "Documents", items: ["PDF"] },
  { label: "Audio", items: ["MP3", "WAV", "OGG", "M4A", "FLAC", "AAC"] },
];

// ---- Trust strip ----
const trust = [
  { t: "Nothing uploaded", icon: "lock" },
  { t: "No signup, ever", icon: "user" },
  { t: "Unlimited & free", icon: "infinity" },
  { t: "Works offline", icon: "wifi" },
  { t: "Any browser", icon: "globe" },
];

function trustIcon(kind: string): string[] {
  switch (kind) {
    case "lock": return ['<rect x="3" y="11" width="18" height="11" rx="2"/>', '<path d="M7 11V7a5 5 0 0 1 10 0v4"/>'];
    case "user": return ['<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>', '<circle cx="12" cy="7" r="4"/>'];
    case "infinity": return ['<path d="M12 12c-2-3-4-4-6-4a4 4 0 0 0 0 8c2 0 4-1 6-4Zm0 0c2 3 4 4 6 4a4 4 0 0 0 0-8c-2 0-4 1-6 4Z"/>'];
    case "wifi": return ['<path d="M5 13a10 10 0 0 1 14 0"/>', '<path d="M8.5 16.5a5 5 0 0 1 7 0"/>', '<path d="M2 8.82a15 15 0 0 1 20 0"/>', '<line x1="12" y1="20" x2="12.01" y2="20"/>'];
    case "globe": return ['<circle cx="12" cy="12" r="10"/>', '<path d="M2 12h20"/>', '<path d="M12 2a15 15 0 0 1 0 20 15 15 0 0 1 0-20"/>'];
    default: return ['<circle cx="12" cy="12" r="10"/>'];
  }
}

function toolIcon(kind: string): string[] {
  switch (kind) {
    case "pdf": return ['<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>', '<path d="M14 2v6h6"/>'];
    case "audio": return ['<path d="M9 18V5l12-2v13"/>', '<circle cx="6" cy="18" r="3"/>', '<circle cx="18" cy="16" r="3"/>'];
    case "image": return ['<rect x="3" y="3" width="18" height="18" rx="2"/>', '<circle cx="9" cy="9" r="2"/>', '<path d="m21 15-3.5-3.5L11 18"/>'];
    case "bg": return ['<circle cx="6" cy="6" r="3"/>', '<circle cx="6" cy="18" r="3"/>', '<path d="M20 4 8.12 15.88"/>', '<path d="M14.47 14.48 20 20"/>', '<path d="M8.12 8.12 12 12"/>'];
    case "upscale": return ['<path d="M3 7V5a2 2 0 0 1 2-2h2"/>', '<path d="M17 3h2a2 2 0 0 1 2 2v2"/>', '<path d="M21 17v2a2 2 0 0 1-2 2h-2"/>', '<path d="M7 21H5a2 2 0 0 1-2-2v-2"/>', '<path d="m9 12 2 2 4-4"/>'];
    default: return ['<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>'];
  }
}

const faqs = [
  { q: "Is ZeroUpload really free and unlimited?", a: "Yes. No signup, no watermark, no per-file limit. There is no server doing the work, so there is nothing to meter or charge for." },
  { q: "Are my files uploaded anywhere?", a: "No. Every conversion runs inside your browser using WebAssembly and Canvas. Your files never leave your device." },
  { q: "Does it work offline?", a: "Yes — once the page has loaded you can disconnect from the internet and it still converts. That's the proof nothing is being uploaded." },
  { q: "What can I convert?", a: "Images (PNG, JPG, WEBP, HEIC, SVG, GIF, BMP), PDF ↔ images, and audio (MP3, WAV, OGG, M4A, FLAC, AAC) — with more tools being added." },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebSite", name: "ZeroUpload", url: Astro.site?.href, description },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <!-- HERO -->
  <section class="mx-auto max-w-3xl px-6 pt-14 pb-2 text-center sm:pt-16">
    <span
      class="float-in inline-flex items-center gap-2 rounded-full border border-mist bg-surface-1 px-4 py-1.5 text-xs font-medium text-stone"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>

    <h1
      class="float-in mt-6 font-display text-5xl leading-[1.05] tracking-tight sm:text-6xl"
      style="animation-delay: 60ms"
    >
      Convert files without<br /> uploading a thing.
    </h1>

    <p
      class="float-in mx-auto mt-5 max-w-xl text-lg text-stone"
      style="animation-delay: 120ms"
    >
      Drop a file below — it's converted entirely inside your browser. No upload,
      no signup, no limits, even works offline.
    </p>
  </section>

  <!-- FLOATING CONSOLE -->
  <section class="px-6 pt-6 pb-2">
    <div class="float-in relative mx-auto max-w-2xl" style="animation-delay: 180ms">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[115%] w-[115%] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent-soft opacity-40 blur-3xl"
      >
      </div>
      <div
        class="console-float rounded-[1.5rem] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-3)] sm:p-7"
      >
        <Converter
          client:load
          sources={sources}
          targets={targets}
          engineMap={engineMap}
          defaultTo="png"
          collapsible
        />
      </div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="mx-auto max-w-4xl px-6 py-8">
    <div
      class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 rounded-[var(--radius-xl)] border border-mist bg-surface-1/60 px-6 py-4"
    >
      {
        trust.map((item) => (
          <div class="flex items-center gap-2 text-sm text-stone">
            <span class="text-accent">
              <svg
                width="17"
                height="17"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={trustIcon(item.icon).join("")}
              />
            </span>
            {item.t}
          </div>
        ))
      }
    </div>
  </section>

  <!-- TOOL SUITES -->
  <section class="mx-auto max-w-5xl px-6 pt-6 pb-4">
    <h2 class="font-display text-2xl">Your private toolkit</h2>
    <p class="mt-1 text-stone">Pick a suite — every tool runs on your device.</p>
    <div class="mt-7 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        toolCards.map((t) => (
          <a
            href={t.href}
            class="tool-card group relative rounded-[1.25rem] border border-mist bg-surface-1 p-6 shadow-[var(--shadow-2)] transition-all duration-300 hover:-translate-y-1.5 hover:border-accent/60 hover:shadow-[var(--shadow-3)]"
          >
            <div>
              {t.badge && (
                <span class="absolute top-4 right-4 rounded-full bg-accent px-2 py-0.5 text-[10px] font-bold tracking-wider text-canvas">
                  {t.badge}
                </span>
              )}
              <span class="mb-4 flex h-11 w-11 items-center justify-center rounded-[var(--radius-md)] bg-accent-soft text-accent">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={toolIcon(t.icon).join("")}
                />
              </span>
              <h3 class="font-display text-lg text-ink transition-colors group-hover:text-accent">
                {t.title}
              </h3>
              <p class="mt-1 text-sm text-stone">{t.blurb}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- POPULAR CONVERSIONS (dense) -->
  <section class="mx-auto max-w-5xl px-6 py-10">
    <h2 class="font-display text-2xl">Popular conversions</h2>
    <p class="mt-1 text-stone">Jump straight to the one you need.</p>
    <div class="mt-7">
      <ConversionGrid conversions={featured} />
    </div>
  </section>

  <!-- SUPPORTED FORMATS -->
  <section class="mx-auto max-w-5xl px-6 py-10">
    <h2 class="font-display text-2xl">Every format, on your device</h2>
    <p class="mt-1 text-stone">No format is ever sent to a server.</p>
    <div class="mt-7 grid gap-4 sm:grid-cols-3">
      {
        formatGroups.map((g) => (
          <div class="rounded-[var(--radius-lg)] border border-mist bg-surface-1 p-5">
            <p class="font-display text-lg text-ink">{g.label}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {g.items.map((f) => (
                <span class="rounded-full border border-mist bg-surface-2 px-3 py-1 font-mono text-xs text-stone">
                  {f}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how" class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="font-display text-3xl">Why ZeroUpload feels like magic</h2>
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      {
        [
          { t: "Nothing is uploaded", d: "Conversion runs in your browser with WebAssembly and Canvas. Your files stay on your device — always." },
          { t: "Instant & unlimited", d: "No queues, no '2 free conversions' walls. There is no server doing the work, so there is nothing to limit." },
          { t: "Works offline", d: "Once the page loads you can disconnect the internet and it still converts. That's the proof it's private." },
        ].map((f) => (
          <div>
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-accent-soft text-accent">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M20 6 9 17l-5-5" />
              </svg>
            </div>
            <h3 class="mt-4 font-display text-xl">{f.t}</h3>
            <p class="mt-2 text-stone">{f.d}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-3xl">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-mist/70">
      {
        faqs.map((f) => (
          <div class="py-5">
            <h3 class="font-display text-lg text-ink">{f.q}</h3>
            <p class="mt-2 text-stone">{f.a}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- PRIVACY STATEMENT -->
  <section id="privacy" class="mx-auto max-w-3xl px-6 pt-8 pb-16 text-center">
    <h2 class="font-display text-3xl">Your files are nobody's business.</h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Other converters upload your private photos and documents to their
      servers. We think that's absurd. ZeroUpload was built on one rule: your
      files never leave your device. No exceptions, no fine print.
    </p>
  </section>
</Layout>
