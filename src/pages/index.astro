---
import Layout from "../layouts/Layout.astro";
import Converter from "../components/Converter.tsx";
import ConversionGrid from "../components/ConversionGrid.astro";
import { CONVERSIONS, FORMAT_BY_ID } from "../data/conversions";

const title =
  "ZeroUpload — Convert Files 100% in Your Browser. Zero Uploads, Zero Limits.";
const description =
  "Convert images, PDFs and audio privately and instantly. Files never leave your device — no upload, no signup, no limits. Works even offline. The private file converter.";

// ---- Universal converter wiring: every conversion in one floating console ----
const sourceIds = Array.from(new Set(CONVERSIONS.map((c) => c.from.id)));
const targetIds = Array.from(new Set(CONVERSIONS.map((c) => c.to.id)));
const engineMap = Object.fromEntries(
  CONVERSIONS.map((c) => [`${c.from.id}-${c.to.id}`, c.engine]),
);
const sources = sourceIds.map((id) => ({
  id,
  name: FORMAT_BY_ID[id].name,
  accept: FORMAT_BY_ID[id].accept ?? `.${id},${FORMAT_BY_ID[id].mime}`,
}));
const targets = targetIds.map((id) => ({ id, name: FORMAT_BY_ID[id].name }));

// ---- Featured conversions (kept) ----
const featuredSlugs = [
  "heic-to-jpg", "png-to-jpg", "webp-to-png", "svg-to-png",
  "pdf-to-jpg", "jpg-to-pdf", "mp3-to-wav", "m4a-to-mp3",
];
const featured = featuredSlugs
  .map((s) => CONVERSIONS.find((c) => c.slug === s))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

// ---- Floating tool cards ----
const toolCards = [
  { title: "PDF Tools", href: "/pdf", blurb: "PDF ↔ images, and more", icon: "pdf" },
  { title: "Audio Tools", href: "/audio-converter", blurb: "MP3, WAV, OGG, M4A, FLAC", icon: "audio" },
  { title: "Image Tools", href: "/image-converter", blurb: "PNG, JPG, WEBP, HEIC, SVG", icon: "image" },
  { title: "AI Background Remover", href: "/background-remover", blurb: "Erase backgrounds on-device", icon: "bg", badge: "AI" },
];

function toolIcon(kind: string): string[] {
  switch (kind) {
    case "pdf":
      return ['<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>', '<path d="M14 2v6h6"/>'];
    case "audio":
      return ['<path d="M9 18V5l12-2v13"/>', '<circle cx="6" cy="18" r="3"/>', '<circle cx="18" cy="16" r="3"/>'];
    case "image":
      return ['<rect x="3" y="3" width="18" height="18" rx="2"/>', '<circle cx="9" cy="9" r="2"/>', '<path d="m21 15-3.5-3.5L11 18"/>'];
    case "bg":
      return ['<circle cx="6" cy="6" r="3"/>', '<circle cx="6" cy="18" r="3"/>', '<path d="M20 4 8.12 15.88"/>', '<path d="M14.47 14.48 20 20"/>', '<path d="M8.12 8.12 12 12"/>'];
    default:
      return ['<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>'];
  }
}

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "ZeroUpload",
    url: Astro.site?.href,
    description,
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <!-- HERO -->
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-2 text-center sm:pt-20">
    <span
      class="float-in inline-flex items-center gap-2 rounded-full border border-mist bg-paper px-4 py-1.5 text-xs font-medium text-stone"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>

    <h1
      class="float-in mt-6 font-display text-5xl leading-[1.05] tracking-tight sm:text-6xl"
      style="animation-delay: 60ms"
    >
      Convert files without<br /> uploading a thing.
    </h1>

    <p
      class="float-in mx-auto mt-5 max-w-xl text-lg text-stone"
      style="animation-delay: 120ms"
    >
      Drop a file below — it's converted entirely inside your browser. No upload,
      no signup, no limits, even works offline.
    </p>
  </section>

  <!-- FLOATING CONSOLE -->
  <section class="px-6 pt-6 pb-4">
    <div class="tilt-scene float-in relative mx-auto max-w-2xl" style="animation-delay: 180ms">
      <!-- soft floating aura behind the console -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[115%] w-[115%] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent-soft opacity-50 blur-3xl"
      >
      </div>

      <div
        data-tilt
        class="tilt-card rounded-[1.5rem] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-3)] sm:p-7"
      >
        <Converter
          client:load
          sources={sources}
          targets={targets}
          engineMap={engineMap}
          defaultTo="png"
          collapsible
        />
      </div>
    </div>
  </section>

  <!-- FLOATING TOOL CARDS -->
  <section class="mx-auto max-w-5xl px-6 py-14">
    <p class="text-center text-sm font-medium tracking-wide text-stone">
      YOUR PRIVATE TOOLKIT
    </p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        toolCards.map((t, i) => (
          <a
            href={t.href}
            class="tool-card float-in group relative rounded-[1.25rem] border border-mist bg-surface-1 p-6 shadow-[var(--shadow-2)] transition-all duration-300 hover:-translate-y-1.5 hover:border-accent/60 hover:shadow-[var(--shadow-3)]"
            style={`animation-delay: ${240 + i * 90}ms`}
          >
            <div
              class="float-bob"
              style={`animation-delay: ${i * 0.5}s; animation-duration: ${5.5 + i * 0.5}s`}
            >
              {t.badge && (
                <span class="absolute top-4 right-4 rounded-full bg-accent px-2 py-0.5 text-[10px] font-bold tracking-wider text-canvas">
                  {t.badge}
                </span>
              )}
              <span class="mb-4 flex h-11 w-11 items-center justify-center rounded-[var(--radius-md)] bg-accent-soft text-accent">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={toolIcon(t.icon).join("")}
                />
              </span>
              <h3 class="font-display text-lg text-ink transition-colors group-hover:text-accent">
                {t.title}
              </h3>
              <p class="mt-1 text-sm text-stone">{t.blurb}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- POPULAR CONVERSIONS -->
  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="font-display text-2xl">Popular conversions</h2>
    <p class="mt-1 text-stone">Pick a conversion — every one runs on your device.</p>
    <div class="mt-8">
      <ConversionGrid conversions={featured} />
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how" class="mx-auto max-w-5xl px-6 py-16">
    <h2 class="font-display text-3xl">Why ZeroUpload feels like magic</h2>
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      {
        [
          {
            t: "Nothing is uploaded",
            d: "Conversion runs in your browser using WebAssembly and Canvas. Your files stay on your device — always.",
          },
          {
            t: "Instant & unlimited",
            d: "No queues, no '2 free conversions' walls. Because there is no server doing the work, there is nothing to limit.",
          },
          {
            t: "Works offline",
            d: "Once the page loads you can disconnect the internet and it still converts. Try it — that's the proof it's private.",
          },
        ].map((f) => (
          <div>
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-accent-soft text-accent">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M20 6 9 17l-5-5" />
              </svg>
            </div>
            <h3 class="mt-4 font-display text-xl">{f.t}</h3>
            <p class="mt-2 text-stone">{f.d}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- PRIVACY STATEMENT -->
  <section id="privacy" class="mx-auto max-w-3xl px-6 py-16 text-center">
    <h2 class="font-display text-3xl">Your files are nobody's business.</h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Other converters upload your private photos and documents to their
      servers. We think that's absurd. ZeroUpload was built on one rule: your
      files never leave your device. No exceptions, no fine print.
    </p>
  </section>
</Layout>

<script>
  // Cursor-tilt for the floating console.
  // Desktop + fine-pointer only, and disabled when the user prefers reduced motion.
  (function () {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const finePointer = window.matchMedia("(pointer: fine)").matches;
    if (prefersReduced || !finePointer) return;

    const card = document.querySelector<HTMLElement>("[data-tilt]");
    const scene = card?.closest<HTMLElement>(".tilt-scene");
    if (!card || !scene) return;

    const MAX_DEG = 5;
    const clamp = (v: number) => Math.max(-1, Math.min(1, v));

    function onMove(e: MouseEvent) {
      const r = card!.getBoundingClientRect();
      const dx = (e.clientX - (r.left + r.width / 2)) / (r.width / 2);
      const dy = (e.clientY - (r.top + r.height / 2)) / (r.height / 2);
      card!.style.setProperty("--tilt-ry", `${(clamp(dx) * MAX_DEG).toFixed(2)}deg`);
      card!.style.setProperty("--tilt-rx", `${(clamp(dy) * -MAX_DEG).toFixed(2)}deg`);
    }
    function reset() {
      card!.style.setProperty("--tilt-ry", "0deg");
      card!.style.setProperty("--tilt-rx", "0deg");
    }

    scene.addEventListener("mousemove", onMove);
    scene.addEventListener("mouseleave", reset);
  })();
</script>
