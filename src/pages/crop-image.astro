---
import Layout from "../layouts/Layout.astro";
import CropImage from "../components/CropImage.tsx";

const title = "Crop Image — Free Online Image Cropper, In Your Browser | ZeroUpload";
const description =
  "Crop images to any size or aspect ratio — 100% in your browser. Free, unlimited, no upload, no signup. Lossless. Your image never leaves your device.";

const faqs = [
  { q: "Is this image cropper free?", a: "Completely — no signup, no watermark, no limit. There is no server, so there is nothing to charge for." },
  { q: "Are my images uploaded?", a: "No. Cropping runs entirely in your browser using the Canvas API. Your image never leaves your device." },
  { q: "Does cropping reduce quality?", a: "No — cropping copies the exact pixels you select, at full quality. (If you switch the output format to JPG/WEBP, those are lossy, but at the high quality used here the difference is negligible.)" },
  { q: "Can I crop to a fixed shape?", a: "Yes — pick 1:1, 4:3 or 16:9, or use Free to drag any rectangle." },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebApplication", name: "ZeroUpload Image Cropper", url: new URL("/crop-image", Astro.site).href, applicationCategory: "MultimediaApplication", operatingSystem: "Any (web browser)", description, offers: { "@type": "Offer", price: "0", priceCurrency: "USD" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-6 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-mist bg-surface-1 px-4 py-1.5 text-xs font-medium text-stone">
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>
    <h1 class="mt-6 font-display text-4xl leading-[1.08] tracking-tight sm:text-5xl">Crop images without<br /> uploading a thing.</h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">Drag to select, pick an aspect ratio, and download — entirely in your browser. Free, unlimited, lossless.</p>
  </section>

  <section class="mx-auto max-w-2xl px-6 py-6">
    <div class="rounded-[1.5rem] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-3)] sm:p-7">
      <CropImage client:load />
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-3xl">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-mist/70">
      {faqs.map((f) => (<div class="py-5"><h3 class="font-display text-lg text-ink">{f.q}</h3><p class="mt-2 text-stone">{f.a}</p></div>))}
    </div>
  </section>
</Layout>
