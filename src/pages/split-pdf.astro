---
import Layout from "../layouts/Layout.astro";
import PdfSplit from "../components/PdfSplit.tsx";

const title = "Split PDF — Extract Pages Free, In Your Browser | ZeroUpload";
const description =
  "Split a PDF or extract a page range — 100% in your browser. Free, unlimited, no upload, no signup. Your PDF never leaves your device.";

const steps = [
  { t: "Drop your PDF", d: "Add a PDF file — it stays on your device." },
  { t: "Pick pages", d: "Extract a page range, or split into single-page PDFs." },
  { t: "Download", d: "Grab your new PDF(s) — no signup." },
];

const faqs = [
  { q: "Is splitting PDFs free?", a: "Completely — no signup, no watermark, no limit. There is no server, so there is nothing to charge for." },
  { q: "Is my PDF uploaded?", a: "No. Splitting runs entirely in your browser. Your PDF never leaves your device." },
  { q: "Can I extract just some pages?", a: "Yes — choose a 'from' and 'to' page to extract that range into a new PDF, or split every page into its own file." },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "ZeroUpload PDF Split",
    url: new URL("/split-pdf", Astro.site).href,
    applicationCategory: "UtilitiesApplication",
    operatingSystem: "Any (web browser)",
    description,
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-6 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-mist bg-surface-1 px-4 py-1.5 text-xs font-medium text-stone">
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>
    <h1 class="mt-6 font-display text-4xl leading-[1.08] tracking-tight sm:text-5xl">
      Split PDFs without<br /> uploading a thing.
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Extract a page range or split into single pages — entirely in your
      browser. Free, unlimited, and your PDF never leaves your device.
    </p>
  </section>

  <section class="mx-auto max-w-2xl px-6 py-6">
    <div class="rounded-[1.5rem] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-3)] sm:p-7">
      <PdfSplit client:load />
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="font-display text-3xl">How it works</h2>
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      {steps.map((s, i) => (
        <div>
          <div class="flex h-11 w-11 items-center justify-center rounded-full bg-accent-soft font-display text-accent">{i + 1}</div>
          <h3 class="mt-4 font-display text-xl">{s.t}</h3>
          <p class="mt-2 text-stone">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-3xl">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-mist/70">
      {faqs.map((f) => (
        <div class="py-5">
          <h3 class="font-display text-lg text-ink">{f.q}</h3>
          <p class="mt-2 text-stone">{f.a}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
