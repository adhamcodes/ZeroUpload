---
import Layout from "../layouts/Layout.astro";
import ConversionGrid from "../components/ConversionGrid.astro";
import { conversionsByCategory, CATEGORIES } from "../data/conversions";

const cat = CATEGORIES.document;
const list = conversionsByCategory("document");

const title = "Free PDF Converter — PDF to Image & Image to PDF | ZeroUpload";
const description =
  "Convert PDF to JPG/PNG and images to PDF instantly in your browser. 100% private — no upload, no signup, no limits. Your documents never leave your device.";

const jsonLd = [
  { "@context": "https://schema.org", "@type": "CollectionPage", name: title, description },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-2xl px-6 pt-16 pb-8 text-center">
    <h1 class="font-display text-4xl tracking-tight sm:text-5xl">{cat.title}</h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">{cat.tagline}</p>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="font-display text-2xl">All PDF conversions</h2>
    <div class="mt-8">
      <ConversionGrid conversions={list} />
    </div>
  </section>
</Layout>
