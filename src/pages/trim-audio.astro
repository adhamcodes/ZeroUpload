---
import Layout from "../layouts/Layout.astro";
import AudioTrim from "../components/AudioTrim.tsx";

const title = "Trim Audio — Free Online Audio Cutter, In Your Browser | ZeroUpload";
const description =
  "Cut or trim an MP3, WAV, M4A or any audio file — 100% in your browser. Free, unlimited, lossless, no upload, no signup. Your audio never leaves your device.";

const faqs = [
  { q: "Is trimming audio free?", a: "Completely — no signup, no watermark, no limit. There is no server, so there is nothing to charge for." },
  { q: "Is my audio uploaded?", a: "No. The cut happens entirely in your browser. Your audio never leaves your device." },
  { q: "Does trimming lose quality?", a: "No — it's lossless. The selected section is copied without re-encoding, so it sounds identical to the original and keeps the same format." },
  { q: "Why is the first use slower?", a: "The first time, your browser downloads a one-time audio engine. After that it's cached, so later edits are quick." },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebApplication", name: "ZeroUpload Audio Trimmer", url: new URL("/trim-audio", Astro.site).href, applicationCategory: "MultimediaApplication", operatingSystem: "Any (web browser)", description, offers: { "@type": "Offer", price: "0", priceCurrency: "USD" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-6 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-mist bg-surface-1 px-4 py-1.5 text-xs font-medium text-stone">
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      100% private · nothing is ever uploaded
    </span>
    <h1 class="mt-6 font-display text-4xl leading-[1.08] tracking-tight sm:text-5xl">Trim audio without<br /> uploading a thing.</h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">Drop an audio file, pick the start and end, and download the cut — lossless and entirely in your browser. Free and unlimited.</p>
  </section>

  <section class="mx-auto max-w-2xl px-6 py-6">
    <div class="rounded-[1.5rem] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-3)] sm:p-7">
      <AudioTrim client:only="react" />
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-3xl">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-mist/70">
      {faqs.map((f) => (<div class="py-5"><h3 class="font-display text-lg text-ink">{f.q}</h3><p class="mt-2 text-stone">{f.a}</p></div>))}
    </div>
  </section>
</Layout>
