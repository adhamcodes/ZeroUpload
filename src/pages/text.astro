---
import Layout from "../layouts/Layout.astro";
import OcrTool from "../components/OcrTool.tsx";

const title = "Image to Text (OCR) — Free, In Your Browser | ZeroUpload";
const description =
  "Extract text from a JPG, PNG or any image with OCR that runs 100% in your browser. Free, unlimited, no upload, no signup. Your image never leaves your device.";

const faqs = [
  { q: "Is this OCR free?", a: "Completely — no signup, no watermark, no limit. There is no server, so there is nothing to charge for." },
  { q: "Is my image uploaded?", a: "No. The OCR engine runs in your browser. Your image never leaves your device. Only the engine and language files are downloaded once, then cached." },
  { q: "How accurate is it?", a: "It's the open-source Tesseract engine, and accuracy depends heavily on the image. Clean, high-contrast, straight text reads very well. Low-resolution photos, unusual fonts, handwriting and busy backgrounds give messier results. We let you edit the text afterwards, and we'd rather set honest expectations than overpromise." },
  { q: "What languages does it read?", a: "Right now it's tuned for English. More languages are on the list." },
  { q: "Can it read a scanned PDF?", a: "This tool reads images. For PDFs that already contain a text layer, use PDF to Text — it pulls the text out directly and is more accurate. For a scanned PDF, screenshot or export the page as an image first, then drop it here." },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebApplication", name: "ZeroUpload Image to Text (OCR)", url: new URL("/text", Astro.site).href, applicationCategory: "UtilitiesApplication", operatingSystem: "Any (web browser)", description, offers: { "@type": "Offer", price: "0", priceCurrency: "USD" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-6 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-mist bg-paper px-4 py-1.5 text-xs font-medium text-stone">
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      OCR runs on your device · nothing is ever uploaded
    </span>
    <h1 class="mt-6 font-display text-4xl leading-[1.08] tracking-tight sm:text-5xl">Pull text out of an image<br /> without uploading it.</h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">Drop a screenshot, photo or scan and read its text with on-device OCR. Free, unlimited, and private — your image never leaves your browser.</p>
  </section>

  <section class="mx-auto max-w-2xl px-6 py-6">
    <div class="rounded-[1.5rem] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-3)] sm:p-7">
      <OcrTool client:only="react" />
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-12">
    <h2 class="font-display text-3xl">Frequently asked questions</h2>
    <div class="mt-8 divide-y divide-mist/70">
      {faqs.map((f) => (<div class="py-5"><h3 class="font-display text-lg text-ink">{f.q}</h3><p class="mt-2 text-stone">{f.a}</p></div>))}
    </div>
  </section>
</Layout>
