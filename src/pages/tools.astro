---
import Layout from "../layouts/Layout.astro";

const title = "All Tools — Free Private File Tools In Your Browser | ZeroUpload";
const description =
  "Every ZeroUpload tool in one place: convert, compress, resize, rotate images; merge and split PDFs; remove backgrounds — all 100% in your browser, free, no upload.";

const groups = [
  {
    label: "Images",
    tools: [
      { name: "Image Converter", href: "/image-converter", blurb: "PNG, JPG, WEBP, HEIC, SVG, GIF, BMP" },
      { name: "Compress Image", href: "/compress-image", blurb: "Shrink file size with a quality slider" },
      { name: "Resize Image", href: "/resize-image", blurb: "By percentage or exact pixels" },
      { name: "Rotate & Flip Image", href: "/rotate-image", blurb: "Turn 90° or mirror" },
      { name: "Crop Image", href: "/crop-image", blurb: "Crop to any size or ratio" },
      { name: "Image Upscaler", href: "/image-upscaler", blurb: "Enlarge images up to 4× (beta)" },
      { name: "AI Background Remover", href: "/background-remover", blurb: "Erase backgrounds on-device" },
    ],
  },
  {
    label: "PDF",
    tools: [
      { name: "PDF Tools", href: "/pdf", blurb: "PDF ↔ images and more" },
      { name: "Merge PDF", href: "/merge-pdf", blurb: "Combine PDFs into one" },
      { name: "Split PDF", href: "/split-pdf", blurb: "Extract pages or split apart" },
      { name: "Rotate PDF", href: "/rotate-pdf", blurb: "Turn pages the right way up" },
      { name: "Compress PDF", href: "/compress-pdf", blurb: "Shrink scans & image-heavy PDFs" },
      { name: "Organize PDF", href: "/organize-pdf", blurb: "Reorder & delete pages" },
      { name: "Images to PDF", href: "/jpg-to-pdf", blurb: "Combine images into a PDF" },
      { name: "PDF to Images", href: "/pdf-to-jpg", blurb: "Export each page as an image" },
      { name: "PDF to Text", href: "/pdf-to-text", blurb: "Extract selectable text" },
    ],
  },
  {
    label: "Audio",
    tools: [
      { name: "Audio Converter", href: "/audio-converter", blurb: "MP3, WAV, OGG, M4A, FLAC, AAC" },
      { name: "Trim Audio", href: "/trim-audio", blurb: "Cut a clip out, lossless" },
      { name: "Merge Audio", href: "/merge-audio", blurb: "Join files into one track" },
      { name: "Compress Audio", href: "/compress-audio", blurb: "Shrink file size to MP3" },
    ],
  },
  {
    label: "Text",
    tools: [
      { name: "Image to Text (OCR)", href: "/text", blurb: "Read text from an image, on-device" },
      { name: "PDF to Text", href: "/pdf-to-text", blurb: "Pull the text layer out of a PDF" },
    ],
  },
];

const allTools = groups.flatMap((g) => g.tools);
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "ZeroUpload Tools",
    itemListElement: allTools.map((t, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: t.name,
      url: new URL(t.href, Astro.site).href,
    })),
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-8 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-mist bg-surface-1 px-4 py-1.5 text-xs font-medium text-stone">
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      Every tool runs on your device
    </span>
    <h1 class="mt-6 font-display text-4xl leading-[1.08] tracking-tight sm:text-5xl">
      All your file tools, in one private place.
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Convert, compress, resize, rotate, merge, split, and erase backgrounds —
      free, unlimited, and nothing ever leaves your browser.
    </p>
  </section>

  {
    groups.map((g) => (
      <section class="mx-auto max-w-5xl px-6 py-6">
        <h2 class="font-display text-2xl">{g.label}</h2>
        <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {g.tools.map((t) => (
            <a
              href={t.href}
              class="group rounded-[var(--radius-lg)] border border-mist bg-surface-1 p-5 shadow-[var(--shadow-1)] transition-all hover:-translate-y-1 hover:border-accent/60 hover:shadow-[var(--shadow-2)]"
            >
              <h3 class="font-display text-lg text-ink transition-colors group-hover:text-accent">
                {t.name}
              </h3>
              <p class="mt-1 text-sm text-stone">{t.blurb}</p>
            </a>
          ))}
        </div>
      </section>
    ))
  }

  <section class="mx-auto max-w-3xl px-6 py-16 text-center">
    <h2 class="font-display text-3xl">Your files are nobody's business.</h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-stone">
      Every tool here runs entirely in your browser. No upload, no signup, no
      limits — your files never leave your device.
    </p>
  </section>
</Layout>
