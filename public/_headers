# Cloudflare Pages headers

# Hashed build assets are immutable — cache hard.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted ffmpeg core (large) — cache a week (filename isn't content-hashed).
/ffmpeg/*
  Cache-Control: public, max-age=604800

# Baseline security headers (do NOT enable cross-origin isolation —
# the single-threaded ffmpeg core does not need it, and isolation would
# break third-party fonts/ads).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
